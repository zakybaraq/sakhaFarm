    "bcrypt": "^6.0.0"
  },
  "devDependencies": {
    "bun-types": "^1.2.0",
    "typescript": "^5.8.0",
    "drizzle-kit": "^0.31.0",
    "vitest": "^3.1.0",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.15.0"
